{
  "name": "prettier-plugin-sieve",
  "version": "0.1.0",
  "description": "Prettier plugin for Sieve email filtering scripts (RFC 5228)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate-parser": "peggy --format es --dts -o src/parser/generated/sieve-parser.js src/parser/sieve.pegjs",
    "typecheck": "tsc --noEmit --project tsconfig.build.json",
    "prebuild": "npm run generate-parser && npm run typecheck",
    "build": "tsc --project tsconfig.build.json && mkdir -p dist/parser/generated && cp -R src/parser/generated/. dist/parser/generated",
    "dev": "tsc --project tsconfig.build.json --watch",
    "prepublishOnly": "npm run build && npm test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:examples": "bash ./scripts/run-example-checks.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs}": [
      "eslint --max-warnings=0",
      "prettier --check"
    ],
    "*.{json,md,yml,sh}": []
  },
  "keywords": [
    "prettier",
    "prettier-plugin",
    "sieve",
    "email",
    "filter"
  ],
  "license": "MIT",
  "peerDependencies": {
    "prettier": ">=3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "peggy": "^4.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jaiew/prettier-plugin-sieve.git"
  },
  "homepage": "https://github.com/jaiew/prettier-plugin-sieve#readme",
  "bugs": {
    "url": "https://github.com/jaiew/prettier-plugin-sieve/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
